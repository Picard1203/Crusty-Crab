@startuml Krusty Crab - Layered Architecture
!pragma layout smetana

top to bottom direction

skinparam packageStyle rectangle
skinparam packageFontStyle bold
skinparam ArrowColor #444444
skinparam ComponentBorderColor #666666
skinparam componentStyle rectangle

package "Presentation Layer" #DDEEFF {
    [auth_router]
    [order_router]
    [menu_router]
    [profits_router]
    [statistics_router]
    [user_router]
}

package "Business Logic Layer" #DDFFD4 {
    [AuthService]
    [OrderService]
    [MenuItemService]
    [StatisticsService]
    [UserService]
}

package "Data Access Layer" #FFF3CC {
    package "Interfaces (ABC)" #FFFBE8 {
        [OrderRepository]
        [MenuItemRepository]
        [UserRepository]
        [CounterRepository]
    }
    package "MongoDB Implementations" #FFFBE8 {
        [MongoOrderRepository]
        [MongoMenuItemRepository]
        [MongoUserRepository]
        [MongoCounterRepository]
    }
}

package "Factory Layer" #FFE8F0 {
    [OrderFactory]
    [MenuItemFactory]
}

package "Infrastructure" #EEE8FF {
    [Database <<ABC>>]
    [MongoDatabase]
    [MongoDB Replica Set]
}

package "Cross-Cutting" #F5F5F5 {
    [deps.py - Composition Root]
    [RequestLoggingMiddleware]
    [Settings]
    [Logging]
}

' Presentation -> Business Logic
[auth_router]       --> [AuthService]
[order_router]      --> [OrderService]
[menu_router]       --> [MenuItemService]
[profits_router]    --> [StatisticsService]
[statistics_router] --> [StatisticsService]
[user_router]       --> [UserService]

' Business Logic -> Data Access
[AuthService]       --> [UserRepository]
[OrderService]      --> [OrderRepository]
[OrderService]      --> [MenuItemRepository]
[MenuItemService]   --> [MenuItemRepository]
[StatisticsService] --> [OrderRepository]
[StatisticsService] --> [MenuItemRepository]
[UserService]       --> [UserRepository]

' Business Logic -> Factories
[OrderService]      --> [OrderFactory]
[MenuItemService]   --> [MenuItemFactory]

' Interfaces -> Implementations
[OrderRepository]     <|-- [MongoOrderRepository]
[MenuItemRepository]  <|-- [MongoMenuItemRepository]
[UserRepository]      <|-- [MongoUserRepository]
[CounterRepository]   <|-- [MongoCounterRepository]

' Factories -> Repositories
[OrderFactory]    --> [CounterRepository]
[OrderFactory]    --> [MenuItemRepository]
[MenuItemFactory] --> [CounterRepository]

' Infrastructure
[Database <<ABC>>]       <|-- [MongoDatabase]
[MongoDatabase]          --> [MongoDB Replica Set]
[MongoOrderRepository]   --> [MongoDB Replica Set]
[MongoMenuItemRepository]--> [MongoDB Replica Set]
[MongoUserRepository]    --> [MongoDB Replica Set]
[MongoCounterRepository] --> [MongoDB Replica Set]

@enduml
